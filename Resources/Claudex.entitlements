<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime blocks Apple Events unless this entitlement is present. We use
         Apple Events to ask Terminal/iTerm for the frontmost tab's tty. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Not sandboxed: we read keychain items and inspect our own processes. -->
</dict>
</plist>
